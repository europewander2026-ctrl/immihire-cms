generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Blog {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique
  content   String   // Rich text (HTML)
  imageUrl  String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Consultation {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  message   String
  status    String   @default("PENDING") // PENDING, REVIEWED, CONTACTED
  createdAt DateTime @default(now())
}

model Subscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model SiteSettings {
  id         Int      @id @default(1)
  logoUrl    String?
  faviconUrl String?
}
